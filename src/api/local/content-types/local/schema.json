    "lat": {
      "type": "string"
    },
    "lng": {
      "type": "string"
    },
    "coordenadas": {
      "type": "json"
    },
    "Logo": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
